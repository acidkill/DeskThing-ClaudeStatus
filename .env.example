# Clawdmeter — example environment for local development.
# Copy to .env and adjust. Real .env files are gitignored.

# Override credentials path used by the server (otherwise the user-facing setting wins).
# CLAWDMETER_CREDENTIALS_PATH=~/.claude/.credentials.json

# Optional: bump server log verbosity. Accepts: debug | info | warn | error
# CLAWDMETER_LOG_LEVEL=info
